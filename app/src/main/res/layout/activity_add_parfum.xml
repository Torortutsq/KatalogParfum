<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_light_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kembali"
            android:textAllCaps="false"
            app:backgroundTint="@color/md_theme_light_secondary"
            app:cornerRadius="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_hero"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tambah Parfum"
                android:textColor="@color/md_theme_light_onPrimaryContainer"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Masukkan data parfum designer baru"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/md_theme_light_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/divider_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Parfum"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etNamaParfum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_soft_input"
                    android:hint="Contoh: Bleu de Chanel"
                    android:padding="14dp"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Brand"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etBrand"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_soft_input"
                    android:hint="Contoh: Chanel"
                    android:padding="14dp"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Gender"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_soft_input"
                    android:hint="Pria / Wanita / Unisex"
                    android:padding="14dp"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Aroma"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etAroma"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_soft_input"
                    android:hint="Fresh, Woody, Floral, Sweet"
                    android:padding="14dp"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Ketahanan"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etKetahanan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_soft_input"
                    android:hint="Contoh: 8-10 jam"
                    android:padding="14dp"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Harga"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etHarga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_soft_input"
                    android:hint="Contoh: 1850000"
                    android:inputType="number"
                    android:padding="14dp"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textColorHint="@color/text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSimpan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="Simpan Data"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:backgroundTint="@color/md_theme_light_primary"
                    app:cornerRadius="18dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>