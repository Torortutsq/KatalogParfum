<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_light_background"
    android:padding="20dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.38" />

    <LinearLayout
        android:id="@+id/leftAdd"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guidelineAdd">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tambah Parfum"
                android:textColor="@color/md_theme_light_onPrimaryContainer"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Input data parfum designer"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        app:cardBackgroundColor="@color/md_theme_light_surface"
        app:cardCornerRadius="22dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/divider_soft"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guidelineAdd"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Parfum"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etNamaParfum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_soft_input"
                    android:hint="Contoh: Bleu de Chanel"
                    android:padding="14dp"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Brand"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etBrand"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_soft_input"
                    android:hint="Contoh: Chanel"
                    android:padding="14dp"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Gender"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_soft_input"
                    android:hint="Pria / Wanita / Unisex"
                    android:padding="14dp"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Aroma"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etAroma"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_soft_input"
                    android:hint="Fresh, Woody, Floral, Sweet"
                    android:padding="14dp"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Ketahanan"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etKetahanan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_soft_input"
                    android:hint="Contoh: 8-10 jam"
                    android:padding="14dp"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textColorHint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Harga"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etHarga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_soft_input"
                    android:hint="Contoh: 1850000"
                    android:inputType="number"
                    android:padding="14dp"
                    android:textColor="@color/md_theme_light_onSurface"
                    android:textColorHint="@color/text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSimpan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="Simpan Data"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:backgroundTint="@color/md_theme_light_primary"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackAdd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Kembali ke Home"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:backgroundTint="@color/md_theme_light_secondary"
                    app:cornerRadius="18dp" />
            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>